@prefix : <http://example.org/lpbf#> .
@prefix lpbf: <http://example.org/lpbf#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Ontology
#################################################################

<http://example.org/lpbf>
    rdf:type owl:Ontology ;
    rdfs:label "LPBF 製程監測、模擬比較與品質診斷本體"@zh ;
    rdfs:label "LPBF Process Monitoring, Simulation Comparison and Quality Diagnosis Ontology"@en ;
    rdfs:comment "此本體以五個主要大標描述 LPBF 核心本體、製程知識批次、Runtime 監測視窗、模擬資料與實際品質資料比較，以及品質判斷、異常診斷與參數修正建議。"@zh .

#################################################################
# Main Classes - 五個大標
#################################################################

:LPBFCoreOntology
    rdf:type owl:Class ;
    rdfs:label "LPBF 核心本體"@zh ;
    rdfs:label "LPBF Core Ontology"@en ;
    rdfs:comment "定義 LPBF 系統中的機台、材料、製程、幾何、品質與診斷等核心概念。"@zh .

:LPBFProcessKnowledgeBatch
    rdf:type owl:Class ;
    rdfs:label "LPBF 製程知識批次"@zh ;
    rdfs:label "LPBF Process Knowledge Batch"@en ;
    rdfs:comment "用來匯入與管理材料參數、機台參數、製程參數、STL、LaserPath 與 Layer 資料。"@zh .

:LPBFRuntimeMonitoringWindow
    rdf:type owl:Class ;
    rdfs:label "LPBF Runtime 監測視窗"@zh ;
    rdfs:label "LPBF Runtime Monitoring Window"@en ;
    rdfs:comment "整合實際加工影像、感測資料、模擬資料與即時加工狀態。"@zh .

:SimulationActualQualityComparison
    rdf:type owl:Class ;
    rdfs:label "模擬資料與實際品質資料比較"@zh ;
    rdfs:label "Simulation and Actual Quality Comparison"@en ;
    rdfs:comment "比較模擬資料與實際工件品質資料，作為後續品質判斷、異常診斷與參數修正的依據。"@zh .

:QualityDiagnosisAndParameterCorrection
    rdf:type owl:Class ;
    rdfs:label "品質判斷、異常診斷、參數修正建議"@zh ;
    rdfs:label "Quality Diagnosis and Parameter Correction"@en ;
    rdfs:comment "整合品質判斷、異常診斷與參數修正建議，是 LPBF 製程分析的最終輸出結果。"@zh .

#################################################################
# Supporting Classes - 核心本體下的概念
#################################################################

:LPBFMachine
    rdf:type owl:Class ;
    rdfs:label "LPBF 機台"@zh ;
    rdfs:label "LPBF Machine"@en .

:Material
    rdf:type owl:Class ;
    rdfs:label "材料"@zh ;
    rdfs:label "Material"@en .

:Process
    rdf:type owl:Class ;
    rdfs:label "製程"@zh ;
    rdfs:label "Process"@en .

:GeometryData
    rdf:type owl:Class ;
    rdfs:label "幾何資料"@zh ;
    rdfs:label "Geometry Data"@en .

:QualityData
    rdf:type owl:Class ;
    rdfs:label "品質資料"@zh ;
    rdfs:label "Quality Data"@en .

:Diagnosis
    rdf:type owl:Class ;
    rdfs:label "診斷"@zh ;
    rdfs:label "Diagnosis"@en .

#################################################################
# Supporting Classes - 製程知識批次資料
#################################################################

:MaterialParameter
    rdf:type owl:Class ;
    rdfs:label "材料參數"@zh ;
    rdfs:label "Material Parameter"@en .

:MachineParameter
    rdf:type owl:Class ;
    rdfs:label "機台參數"@zh ;
    rdfs:label "Machine Parameter"@en .

:ProcessParameter
    rdf:type owl:Class ;
    rdfs:label "製程參數"@zh ;
    rdfs:label "Process Parameter"@en .

:STLModel
    rdf:type owl:Class ;
    rdfs:subClassOf :GeometryData ;
    rdfs:label "STL 工件模型"@zh ;
    rdfs:label "STL Model"@en .

:LaserPath
    rdf:type owl:Class ;
    rdfs:subClassOf :GeometryData ;
    rdfs:label "LaserPath 雷射掃描路徑"@zh ;
    rdfs:label "Laser Path"@en .

:LayerData
    rdf:type owl:Class ;
    rdfs:subClassOf :GeometryData ;
    rdfs:label "Layer 層資料"@zh ;
    rdfs:label "Layer Data"@en .

#################################################################
# Supporting Classes - Runtime 監測視窗資料
#################################################################

:ActualProcessImage
    rdf:type owl:Class ;
    rdfs:label "實際加工影像"@zh ;
    rdfs:label "Actual Process Image"@en .

:MeltPoolImage
    rdf:type owl:Class ;
    rdfs:subClassOf :ActualProcessImage ;
    rdfs:label "熔池影像"@zh ;
    rdfs:label "Melt Pool Image"@en .

:LayerSurfaceImage
    rdf:type owl:Class ;
    rdfs:subClassOf :ActualProcessImage ;
    rdfs:label "層面表面影像"@zh ;
    rdfs:label "Layer Surface Image"@en .

:SensorData
    rdf:type owl:Class ;
    rdfs:label "感測資料"@zh ;
    rdfs:label "Sensor Data"@en .

:SimulationData
    rdf:type owl:Class ;
    rdfs:label "模擬資料"@zh ;
    rdfs:label "Simulation Data"@en .

:PhysicalSimulation
    rdf:type owl:Class ;
    rdfs:subClassOf :SimulationData ;
    rdfs:label "物理模擬"@zh ;
    rdfs:label "Physical Simulation"@en .

:ThermalCoverageSimulation
    rdf:type owl:Class ;
    rdfs:subClassOf :SimulationData ;
    rdfs:label "熱覆蓋模擬"@zh ;
    rdfs:label "Thermal Coverage Simulation"@en .

:CoolingSimulation
    rdf:type owl:Class ;
    rdfs:subClassOf :SimulationData ;
    rdfs:label "冷卻模擬"@zh ;
    rdfs:label "Cooling Simulation"@en .

:FullPartSimulation
    rdf:type owl:Class ;
    rdfs:subClassOf :SimulationData ;
    rdfs:label "完整工件模擬"@zh ;
    rdfs:label "Full Part Simulation"@en .

:RuntimeProcessState
    rdf:type owl:Class ;
    rdfs:label "即時加工狀態"@zh ;
    rdfs:label "Runtime Process State"@en .

#################################################################
# Supporting Classes - 實際品質資料
#################################################################

:ActualWorkpieceQuality
    rdf:type owl:Class ;
    rdfs:subClassOf :QualityData ;
    rdfs:label "實際工件品質資料"@zh ;
    rdfs:label "Actual Workpiece Quality Data"@en .

:SurfaceHeightMap
    rdf:type owl:Class ;
    rdfs:subClassOf :ActualWorkpieceQuality ;
    rdfs:label "表面高度圖"@zh ;
    rdfs:label "Surface Height Map"@en .

:SurfaceRoughness
    rdf:type owl:Class ;
    rdfs:subClassOf :ActualWorkpieceQuality ;
    rdfs:label "表面粗糙度"@zh ;
    rdfs:label "Surface Roughness"@en .

:PorosityMeasurement
    rdf:type owl:Class ;
    rdfs:subClassOf :ActualWorkpieceQuality ;
    rdfs:label "孔隙量測"@zh ;
    rdfs:label "Porosity Measurement"@en .

:DimensionalError
    rdf:type owl:Class ;
    rdfs:subClassOf :ActualWorkpieceQuality ;
    rdfs:label "尺寸誤差"@zh ;
    rdfs:label "Dimensional Error"@en .

#################################################################
# Supporting Classes - 品質判斷、異常診斷、修正建議
#################################################################

:QualityDecision
    rdf:type owl:Class ;
    rdfs:subClassOf :QualityDiagnosisAndParameterCorrection ;
    rdfs:label "品質判斷"@zh ;
    rdfs:label "Quality Decision"@en .

:AbnormalDiagnosis
    rdf:type owl:Class ;
    rdfs:subClassOf :QualityDiagnosisAndParameterCorrection ;
    rdfs:label "異常診斷"@zh ;
    rdfs:label "Abnormal Diagnosis"@en .

:ParameterCorrectionSuggestion
    rdf:type owl:Class ;
    rdfs:subClassOf :QualityDiagnosisAndParameterCorrection ;
    rdfs:label "參數修正建議"@zh ;
    rdfs:label "Parameter Correction Suggestion"@en .

:DefectType
    rdf:type owl:Class ;
    rdfs:subClassOf :AbnormalDiagnosis ;
    rdfs:label "缺陷類型"@zh ;
    rdfs:label "Defect Type"@en .

:LackOfFusion
    rdf:type owl:Class ;
    rdfs:subClassOf :DefectType ;
    rdfs:label "未熔合"@zh ;
    rdfs:label "Lack of Fusion"@en .

:Overheating
    rdf:type owl:Class ;
    rdfs:subClassOf :DefectType ;
    rdfs:label "過熱"@zh ;
    rdfs:label "Overheating"@en .

:Balling
    rdf:type owl:Class ;
    rdfs:subClassOf :DefectType ;
    rdfs:label "球化"@zh ;
    rdfs:label "Balling"@en .

:Keyhole
    rdf:type owl:Class ;
    rdfs:subClassOf :DefectType ;
    rdfs:label "鑰孔效應"@zh ;
    rdfs:label "Keyhole"@en .

#################################################################
# Object Properties - 五個大標主流程
#################################################################

:hasKnowledgeBatch
    rdf:type owl:ObjectProperty ;
    rdfs:label "具有製程知識批次"@zh ;
    rdfs:label "has knowledge batch"@en ;
    rdfs:domain :LPBFCoreOntology ;
    rdfs:range :LPBFProcessKnowledgeBatch .

:hasRuntimeMonitoringWindow
    rdf:type owl:ObjectProperty ;
    rdfs:label "具有 Runtime 監測視窗"@zh ;
    rdfs:label "has runtime monitoring window"@en ;
    rdfs:domain :LPBFProcessKnowledgeBatch ;
    rdfs:range :LPBFRuntimeMonitoringWindow .

:generatesComparison
    rdf:type owl:ObjectProperty ;
    rdfs:label "產生模擬資料與實際品質資料比較"@zh ;
    rdfs:label "generates simulation actual quality comparison"@en ;
    rdfs:domain :LPBFRuntimeMonitoringWindow ;
    rdfs:range :SimulationActualQualityComparison .

:outputsDiagnosisAndCorrection
    rdf:type owl:ObjectProperty ;
    rdfs:label "輸出品質判斷、異常診斷、參數修正建議"@zh ;
    rdfs:label "outputs diagnosis and correction"@en ;
    rdfs:domain :SimulationActualQualityComparison ;
    rdfs:range :QualityDiagnosisAndParameterCorrection .

#################################################################
# Object Properties - 核心本體定義
#################################################################

:definesMachine
    rdf:type owl:ObjectProperty ;
    rdfs:label "定義機台"@zh ;
    rdfs:label "defines machine"@en ;
    rdfs:domain :LPBFCoreOntology ;
    rdfs:range :LPBFMachine .

:definesMaterial
    rdf:type owl:ObjectProperty ;
    rdfs:label "定義材料"@zh ;
    rdfs:label "defines material"@en ;
    rdfs:domain :LPBFCoreOntology ;
    rdfs:range :Material .

:definesProcess
    rdf:type owl:ObjectProperty ;
    rdfs:label "定義製程"@zh ;
    rdfs:label "defines process"@en ;
    rdfs:domain :LPBFCoreOntology ;
    rdfs:range :Process .

:definesGeometry
    rdf:type owl:ObjectProperty ;
    rdfs:label "定義幾何"@zh ;
    rdfs:label "defines geometry"@en ;
    rdfs:domain :LPBFCoreOntology ;
    rdfs:range :GeometryData .

:definesQuality
    rdf:type owl:ObjectProperty ;
    rdfs:label "定義品質"@zh ;
    rdfs:label "defines quality"@en ;
    rdfs:domain :LPBFCoreOntology ;
    rdfs:range :QualityData .

:definesDiagnosis
    rdf:type owl:ObjectProperty ;
    rdfs:label "定義診斷"@zh ;
    rdfs:label "defines diagnosis"@en ;
    rdfs:domain :LPBFCoreOntology ;
    rdfs:range :Diagnosis .

#################################################################
# Object Properties - 製程知識批次匯入資料
#################################################################

:importsMaterialParameter
    rdf:type owl:ObjectProperty ;
    rdfs:label "匯入材料參數"@zh ;
    rdfs:label "imports material parameter"@en ;
    rdfs:domain :LPBFProcessKnowledgeBatch ;
    rdfs:range :MaterialParameter .

:importsMachineParameter
    rdf:type owl:ObjectProperty ;
    rdfs:label "匯入機台參數"@zh ;
    rdfs:label "imports machine parameter"@en ;
    rdfs:domain :LPBFProcessKnowledgeBatch ;
    rdfs:range :MachineParameter .

:importsProcessParameter
    rdf:type owl:ObjectProperty ;
    rdfs:label "匯入製程參數"@zh ;
    rdfs:label "imports process parameter"@en ;
    rdfs:domain :LPBFProcessKnowledgeBatch ;
    rdfs:range :ProcessParameter .

:importsSTL
    rdf:type owl:ObjectProperty ;
    rdfs:label "匯入 STL"@zh ;
    rdfs:label "imports STL"@en ;
    rdfs:domain :LPBFProcessKnowledgeBatch ;
    rdfs:range :STLModel .

:importsLaserPath
    rdf:type owl:ObjectProperty ;
    rdfs:label "匯入 LaserPath"@zh ;
    rdfs:label "imports LaserPath"@en ;
    rdfs:domain :LPBFProcessKnowledgeBatch ;
    rdfs:range :LaserPath .

:importsLayerData
    rdf:type owl:ObjectProperty ;
    rdfs:label "匯入 Layer 資料"@zh ;
    rdfs:label "imports layer data"@en ;
    rdfs:domain :LPBFProcessKnowledgeBatch ;
    rdfs:range :LayerData .

#################################################################
# Object Properties - Runtime 監測視窗整合資料
#################################################################

:integratesImageData
    rdf:type owl:ObjectProperty ;
    rdfs:label "整合實際加工影像"@zh ;
    rdfs:label "integrates image data"@en ;
    rdfs:domain :LPBFRuntimeMonitoringWindow ;
    rdfs:range :ActualProcessImage .

:integratesSensorData
    rdf:type owl:ObjectProperty ;
    rdfs:label "整合感測資料"@zh ;
    rdfs:label "integrates sensor data"@en ;
    rdfs:domain :LPBFRuntimeMonitoringWindow ;
    rdfs:range :SensorData .

:integratesSimulationData
    rdf:type owl:ObjectProperty ;
    rdfs:label "整合模擬資料"@zh ;
    rdfs:label "integrates simulation data"@en ;
    rdfs:domain :LPBFRuntimeMonitoringWindow ;
    rdfs:range :SimulationData .

:integratesRuntimeState
    rdf:type owl:ObjectProperty ;
    rdfs:label "整合即時加工狀態"@zh ;
    rdfs:label "integrates runtime state"@en ;
    rdfs:domain :LPBFRuntimeMonitoringWindow ;
    rdfs:range :RuntimeProcessState .

#################################################################
# Object Properties - 比較與診斷
#################################################################

:comparesSimulationData
    rdf:type owl:ObjectProperty ;
    rdfs:label "比較模擬資料"@zh ;
    rdfs:label "compares simulation data"@en ;
    rdfs:domain :SimulationActualQualityComparison ;
    rdfs:range :SimulationData .

:comparesActualQualityData
    rdf:type owl:ObjectProperty ;
    rdfs:label "比較實際品質資料"@zh ;
    rdfs:label "compares actual quality data"@en ;
    rdfs:domain :SimulationActualQualityComparison ;
    rdfs:range :ActualWorkpieceQuality .

:hasQualityDecision
    rdf:type owl:ObjectProperty ;
    rdfs:label "具有品質判斷"@zh ;
    rdfs:label "has quality decision"@en ;
    rdfs:domain :QualityDiagnosisAndParameterCorrection ;
    rdfs:range :QualityDecision .

:hasAbnormalDiagnosis
    rdf:type owl:ObjectProperty ;
    rdfs:label "具有異常診斷"@zh ;
    rdfs:label "has abnormal diagnosis"@en ;
    rdfs:domain :QualityDiagnosisAndParameterCorrection ;
    rdfs:range :AbnormalDiagnosis .

:hasParameterCorrectionSuggestion
    rdf:type owl:ObjectProperty ;
    rdfs:label "具有參數修正建議"@zh ;
    rdfs:label "has parameter correction suggestion"@en ;
    rdfs:domain :QualityDiagnosisAndParameterCorrection ;
    rdfs:range :ParameterCorrectionSuggestion .

:detectsDefectType
    rdf:type owl:ObjectProperty ;
    rdfs:label "偵測缺陷類型"@zh ;
    rdfs:label "detects defect type"@en ;
    rdfs:domain :AbnormalDiagnosis ;
    rdfs:range :DefectType .

#################################################################
# Data Properties
#################################################################

:hasFilePath
    rdf:type owl:DatatypeProperty ;
    rdfs:label "檔案路徑"@zh ;
    rdfs:label "file path"@en ;
    rdfs:range xsd:string .

:hasLayerID
    rdf:type owl:DatatypeProperty ;
    rdfs:label "Layer 編號"@zh ;
    rdfs:label "layer ID"@en ;
    rdfs:domain :LayerData ;
    rdfs:range xsd:string .

:hasLaserPower
    rdf:type owl:DatatypeProperty ;
    rdfs:label "雷射功率"@zh ;
    rdfs:label "laser power"@en ;
    rdfs:domain :ProcessParameter ;
    rdfs:range xsd:double .

:hasScanSpeed
    rdf:type owl:DatatypeProperty ;
    rdfs:label "掃描速度"@zh ;
    rdfs:label "scan speed"@en ;
    rdfs:domain :ProcessParameter ;
    rdfs:range xsd:double .

:hasHatchSpacing
    rdf:type owl:DatatypeProperty ;
    rdfs:label "掃描間距"@zh ;
    rdfs:label "hatch spacing"@en ;
    rdfs:domain :ProcessParameter ;
    rdfs:range xsd:double .

:hasLayerThickness
    rdf:type owl:DatatypeProperty ;
    rdfs:label "層厚"@zh ;
    rdfs:label "layer thickness"@en ;
    rdfs:domain :ProcessParameter ;
    rdfs:range xsd:double .

:hasTemperatureMax
    rdf:type owl:DatatypeProperty ;
    rdfs:label "最高溫度"@zh ;
    rdfs:label "maximum temperature"@en ;
    rdfs:domain :SimulationData ;
    rdfs:range xsd:double .

:hasCoolingTime
    rdf:type owl:DatatypeProperty ;
    rdfs:label "冷卻時間"@zh ;
    rdfs:label "cooling time"@en ;
    rdfs:domain :SimulationData ;
    rdfs:range xsd:double .

:hasMeltPoolArea
    rdf:type owl:DatatypeProperty ;
    rdfs:label "熔池面積"@zh ;
    rdfs:label "melt pool area"@en ;
    rdfs:domain :SimulationData ;
    rdfs:range xsd:double .

:hasQualityError
    rdf:type owl:DatatypeProperty ;
    rdfs:label "品質誤差"@zh ;
    rdfs:label "quality error"@en ;
    rdfs:domain :SimulationActualQualityComparison ;
    rdfs:range xsd:double .

:hasDecisionLabel
    rdf:type owl:DatatypeProperty ;
    rdfs:label "判斷標籤"@zh ;
    rdfs:label "decision label"@en ;
    rdfs:domain :QualityDecision ;
    rdfs:range xsd:string .

:hasSuggestionText
    rdf:type owl:DatatypeProperty ;
    rdfs:label "建議文字"@zh ;
    rdfs:label "suggestion text"@en ;
    rdfs:domain :ParameterCorrectionSuggestion ;
    rdfs:range xsd:string .

#################################################################
# Individuals - 五個大標主流程實例
#################################################################

:LPBF_Core_Ontology_001
    rdf:type owl:NamedIndividual ,
        :LPBFCoreOntology ;
    rdfs:label "LPBF 核心本體 001"@zh ;
    :definesMachine :LPBF_Machine_001 ;
    :definesMaterial :Material_001 ;
    :definesProcess :Process_001 ;
    :definesGeometry :Geometry_Data_001 ;
    :definesQuality :Quality_Data_001 ;
    :definesDiagnosis :Diagnosis_001 ;
    :hasKnowledgeBatch :LPBF_Process_Knowledge_Batch_001 .

:LPBF_Process_Knowledge_Batch_001
    rdf:type owl:NamedIndividual ,
        :LPBFProcessKnowledgeBatch ;
    rdfs:label "LPBF 製程知識批次 001"@zh ;
    :importsMaterialParameter :Material_Parameter_001 ;
    :importsMachineParameter :Machine_Parameter_001 ;
    :importsProcessParameter :Process_Parameter_001 ;
    :importsSTL :STL_Model_001 ;
    :importsLaserPath :LaserPath_001 ;
    :importsLayerData :Layer_001 ;
    :hasRuntimeMonitoringWindow :Runtime_Monitoring_Window_001 .

:Runtime_Monitoring_Window_001
    rdf:type owl:NamedIndividual ,
        :LPBFRuntimeMonitoringWindow ;
    rdfs:label "LPBF Runtime 監測視窗 001"@zh ;
    :integratesImageData :MeltPool_Image_001 ;
    :integratesImageData :Layer_Surface_Image_001 ;
    :integratesSensorData :Sensor_Data_001 ;
    :integratesSimulationData :Physical_Simulation_001 ;
    :integratesSimulationData :Thermal_Coverage_Simulation_001 ;
    :integratesSimulationData :Cooling_Simulation_001 ;
    :integratesSimulationData :Full_Part_Simulation_001 ;
    :integratesRuntimeState :Runtime_Process_State_001 ;
    :generatesComparison :Simulation_Actual_Quality_Comparison_001 .

:Simulation_Actual_Quality_Comparison_001
    rdf:type owl:NamedIndividual ,
        :SimulationActualQualityComparison ;
    rdfs:label "模擬資料與實際品質資料比較 001"@zh ;
    :comparesSimulationData :Physical_Simulation_001 ;
    :comparesSimulationData :Thermal_Coverage_Simulation_001 ;
    :comparesSimulationData :Cooling_Simulation_001 ;
    :comparesSimulationData :Full_Part_Simulation_001 ;
    :comparesActualQualityData :Actual_Workpiece_Quality_001 ;
    :outputsDiagnosisAndCorrection :Quality_Diagnosis_And_Parameter_Correction_001 ;
    :hasQualityError "5.3"^^xsd:double .

:Quality_Diagnosis_And_Parameter_Correction_001
    rdf:type owl:NamedIndividual ,
        :QualityDiagnosisAndParameterCorrection ;
    rdfs:label "品質判斷、異常診斷、參數修正建議 001"@zh ;
    :hasQualityDecision :Quality_Decision_001 ;
    :hasAbnormalDiagnosis :Abnormal_Diagnosis_001 ;
    :hasParameterCorrectionSuggestion :Parameter_Correction_Suggestion_001 .

#################################################################
# Individuals - 核心本體定義項目
#################################################################

:LPBF_Machine_001
    rdf:type owl:NamedIndividual ,
        :LPBFMachine ;
    rdfs:label "LPBF 機台 001"@zh .

:Material_001
    rdf:type owl:NamedIndividual ,
        :Material ;
    rdfs:label "材料 001"@zh .

:Process_001
    rdf:type owl:NamedIndividual ,
        :Process ;
    rdfs:label "製程 001"@zh .

:Geometry_Data_001
    rdf:type owl:NamedIndividual ,
        :GeometryData ;
    rdfs:label "幾何資料 001"@zh .

:Quality_Data_001
    rdf:type owl:NamedIndividual ,
        :QualityData ;
    rdfs:label "品質資料 001"@zh .

:Diagnosis_001
    rdf:type owl:NamedIndividual ,
        :Diagnosis ;
    rdfs:label "診斷 001"@zh .

#################################################################
# Individuals - 製程知識批次匯入資料
#################################################################

:Material_Parameter_001
    rdf:type owl:NamedIndividual ,
        :MaterialParameter ;
    rdfs:label "材料參數 001"@zh .

:Machine_Parameter_001
    rdf:type owl:NamedIndividual ,
        :MachineParameter ;
    rdfs:label "機台參數 001"@zh .

:Process_Parameter_001
    rdf:type owl:NamedIndividual ,
        :ProcessParameter ;
    rdfs:label "製程參數 001"@zh ;
    :hasLaserPower "200.0"^^xsd:double ;
